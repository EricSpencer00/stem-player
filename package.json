{
  "name": "stemacle",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "description": "Stemacle local-first stem splitter, shuffle instrument, desktop shell, and iOS wrapper.",
  "main": "native/electron/main.cjs",
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "test:browser": "node --test tests/browser-parity.browser.mjs",
    "test:browser:e2e": "STEMACLE_BROWSER_E2E=1 node --test tests/browser-parity.browser.mjs",
    "appstore:verify": "node --test tests/test_appstore_layout.mjs && npm test",
    "site:prepare": "node scripts/prepare-site.mjs",
    "native:prepare": "node scripts/prepare-native.mjs",
    "core:test": "cargo test --manifest-path native/core/Cargo.toml",
    "core:build": "cargo build --release --manifest-path native/core/Cargo.toml",
    "core:fmt": "cargo fmt --manifest-path native/core/Cargo.toml --all",
    "apple:xcframework": "bash scripts/build-apple-xcframework.sh",
    "apple:icons": "bash scripts/gen-app-icons.sh",
    "apple:project": "cd native/apple && xcodegen generate",
    "desktop:test": "cargo test --manifest-path native/desktop/Cargo.toml",
    "desktop:build": "cargo build --release --manifest-path native/desktop/Cargo.toml",
    "desktop:run": "cargo run --manifest-path native/desktop/Cargo.toml",
    "appstore:export-iphone": "node appstore-screenshots/export.js",
    "appstore:export-ipad": "node appstore-screenshots/export-ipad.js",
    "desktop:dev": "node scripts/desktop-dispatch.mjs dev",
    "desktop:pack": "node scripts/desktop-dispatch.mjs pack",
    "desktop:dist": "node scripts/desktop-dispatch.mjs dist",
    "macos:dev": "npm run native:prepare && swift run --package-path native/macos StemacleMac --repo-root \"$PWD\"",
    "macos:build": "npm run native:prepare && swift build --package-path native/macos -c release",
    "macos:package": "npm run macos:build && node scripts/package-macos.mjs",
    "macos:appstore": "STEMACLE_MAC_DISTRIBUTION=appstore npm run macos:package",
    "windows:dev": "npm run native:prepare && electron .",
    "windows:dist": "npm run native:prepare && electron-builder --win nsis --x64",
    "linux:dist": "npm run native:prepare && electron-builder --linux AppImage deb --x64",
    "webui:dev": "npm run native:prepare && node scripts/serve-native.mjs",
    "ios:add": "npm run native:prepare && cap add ios",
    "ios:sync": "npm run native:prepare && cap sync ios",
    "ios:open": "npm run ios:sync && cap open ios",
    "ios:archive": "bash scripts/ios-release.sh archive",
    "ios:testflight": "bash scripts/ios-release.sh testflight",
    "ios:publish": "bash scripts/ios-release.sh publish",
    "ios:validate": "bash scripts/ios-release.sh validate"
  },
  "keywords": [
    "audio",
    "stems",
    "electron",
    "capacitor"
  ],
  "author": "Eric Spencer",
  "license": "UNLICENSED",
  "dependencies": {
    "@capacitor/core": "^8.4.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "puppeteer": "^25.1.0"
  },
  "build": {
    "appId": "com.stemacle.app",
    "productName": "Stemacle Web Workbench",
    "forceCodeSigning": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "index.html",
      "app/**/*",
      "apps/**/*",
      "assets/**/*",
      "privacy/**/*",
      "samples/**/*",
      "support/**/*",
      "native/**/*",
      "scripts/**/*",
      "capacitor.config.json",
      "package.json"
    ],
    "win": {
      "artifactName": "Stemacle-windows-${arch}-setup.${ext}",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "category": "Audio",
      "icon": "native/electron/icon.png",
      "artifactName": "Stemacle-linux-${arch}.${ext}",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
