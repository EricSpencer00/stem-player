{
  "name": "stemacle",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "description": "Stemacle local-first stem splitter: web gold master, native Apple (SwiftUI) and Windows/Linux (Slint) apps over a shared Rust DSP core.",
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "test:browser": "node --test tests/browser-parity.browser.mjs",
    "test:browser:e2e": "STEMACLE_BROWSER_E2E=1 node --test tests/browser-parity.browser.mjs",
    "appstore:verify": "node --test tests/test_appstore_layout.mjs && npm test",
    "site:prepare": "node scripts/prepare-site.mjs",
    "core:test": "cargo test --manifest-path native/core/Cargo.toml",
    "core:build": "cargo build --release --manifest-path native/core/Cargo.toml",
    "core:fmt": "cargo fmt --manifest-path native/core/Cargo.toml --all",
    "golden:gen": "node tests/golden/gen-golden.mjs",
    "models:build": "models/.venv-models/bin/python models/convert_demucs.py",
    "apple:xcframework": "bash scripts/build-apple-xcframework.sh",
    "apple:icons": "bash scripts/gen-app-icons.sh",
    "apple:project": "cd native/apple && xcodegen generate",
    "desktop:test": "cargo test --manifest-path native/desktop/Cargo.toml",
    "desktop:build": "cargo build --release --manifest-path native/desktop/Cargo.toml",
    "desktop:run": "cargo run --manifest-path native/desktop/Cargo.toml",
    "appstore:export-iphone": "node appstore-screenshots/export.js",
    "appstore:export-ipad": "node appstore-screenshots/export-ipad.js",
    "ios:archive": "bash scripts/ios-release.sh archive",
    "ios:testflight": "bash scripts/ios-release.sh testflight",
    "ios:publish": "bash scripts/ios-release.sh publish",
    "ios:validate": "bash scripts/ios-release.sh validate"
  },
  "keywords": [
    "audio",
    "stems"
  ],
  "author": "Eric Spencer",
  "license": "UNLICENSED",
  "devDependencies": {
    "puppeteer": "^25.1.0"
  }
}
